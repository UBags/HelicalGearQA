# ── PyCharm / JetBrains ──────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── Python virtual environments ──────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ── Python cache & compiled files ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Model weights & checkpoints (large binary files) ─────────────────────────
*.pth
*.pt
*.onnx
*.bin
*.safetensors
model_checkpoints/

# ── Images & data (do not commit raw input images) ───────────────────────────
images/
*.bmp
*.png
*.jpg
*.jpeg
*.tiff
*.tif

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs & temporary files ────────────────────────────────────────────────────
*.log
*.tmp
*.temp

# ── Environment variable files ────────────────────────────────────────────────
.env
.env.local